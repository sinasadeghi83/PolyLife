# PolyLife core — environment.
# Copy this file to `.env` and adjust values for your setup.
# `.env` is git-ignored and must NEVER be committed.
# docker-compose reads this file (env_file: .env), so the container uses these
# same values.

# ── Django ──────────────────────────────────────────────────────────────────
# Secret key. Generate a strong one for production.
DJANGO_SECRET_KEY=dev-only-insecure-secret-key-change-me-in-production
# Debug mode. Set to False in production.
DEBUG=True
# Hosts allowed to serve the app. `core` is required so a team gateway can call
# the core (it reaches it as http://core:8000) during forward-auth.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,core

# ── Database ────────────────────────────────────────────────────────────────
# Defaults to a local SQLite file when unset. For Postgres/MySQL use a URL:
#   DATABASE_URL=postgres://user:pass@localhost:5432/polylife
# DATABASE_URL=sqlite:///db.sqlite3

# ── JWT ─────────────────────────────────────────────────────────────────────
# Signing secret (falls back to DJANGO_SECRET_KEY if unset). Use >= 32 chars.
JWT_SECRET=dev-only-insecure-jwt-secret-change-me-in-production
# Token lifetimes, in seconds.
JWT_ACCESS_TTL_SECONDS=900          # 15 minutes
JWT_REFRESH_TTL_SECONDS=604800      # 7 days

# ── Auth cookies ────────────────────────────────────────────────────────────
# Set JWT_COOKIE_SECURE=True behind HTTPS in production.
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# ── Team microservices (optional) ───────────────────────────────────────────
# Comma-separated app labels; empty until team apps are mounted in the core.
# Each listed team also needs its own database via <TEAM>_DATABASE_URL,
# otherwise a per-team SQLite file is used locally.
# TEAM_APPS=team1,team2
# TEAM1_DATABASE_URL=postgres://team1_user:team1pass@db-team1:5432/team1
# TEAM2_DATABASE_URL=postgres://team2_user:team2pass@db-team2:5432/team2
