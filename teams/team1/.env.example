# Team team1 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9101).
TEAM_PORT=9101

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=team1
POSTGRES_USER=team1_user
POSTGRES_PASSWORD=team1pass
DATABASE_URL=postgres://team1_user:team1pass@db:5432/team1

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team1-secret-change-me
