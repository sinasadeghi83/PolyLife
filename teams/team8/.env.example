# Team team8 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9108).
TEAM_PORT=9108

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=team8
POSTGRES_USER=team8_user
POSTGRES_PASSWORD=team8pass
DATABASE_URL=postgres://team8_user:team8pass@db:5432/team8

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team8-secret-change-me
