# Team team6 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9106).
TEAM_PORT=9106

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=team6
POSTGRES_USER=team6_user
POSTGRES_PASSWORD=team6pass
DATABASE_URL=postgres://team6_user:team6pass@db:5432/team6

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team6-secret-change-me
