# Team team3 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9103).
TEAM_PORT=9103

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=team3
POSTGRES_USER=team3_user
POSTGRES_PASSWORD=team3pass
DATABASE_URL=postgres://team3_user:team3pass@db:5432/team3

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team3-secret-change-me
