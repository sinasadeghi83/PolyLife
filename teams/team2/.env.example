# Team team2 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9102).
TEAM_PORT=9102

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=team2
POSTGRES_USER=team2_user
POSTGRES_PASSWORD=team2pass
DATABASE_URL=postgres://team2_user:team2pass@db:5432/team2

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team2-secret-change-me
