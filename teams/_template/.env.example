# Team __TEAM__ — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:__PORT__).
TEAM_PORT=__PORT__

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

# Your team's own database (used once you enable the db + backend services).
POSTGRES_DB=__TEAM__
POSTGRES_USER=__TEAM___user
POSTGRES_PASSWORD=__PASSWORD__
DATABASE_URL=postgres://__TEAM___user:__PASSWORD__@db:5432/__TEAM__

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-__TEAM__-secret-change-me
